# Copy to .env and fill in real values. DO NOT commit the real .env.

# PostgreSQL (shared by gateway-service and classification-service)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/DBNAME?sslmode=require
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# Task #1: AWS RDS — leave unset to keep using the Neon dev DB (docker-compose.yml
# falls back automatically). Set these after `terraform apply` + running
# infrastructure/scripts/migrate_neon_to_rds.sh to cut the gateway over to RDS.
RDS_ENDPOINT=
DB_NAME=private_credit_db
DB_USERNAME=platform_admin
DB_PASSWORD=

# Task #1 dual-DB: Neon as hot backup. When BACKUP_DB_URL is set the gateway
# serves reads/writes from RDS while it is available, fails over to Neon when
# it is not, and mirrors every table into Neon so both databases store the
# uploaded data. BACKUP_DATABASE_URL is the same DB in SQLAlchemy form for the
# classification service. Leave all four empty for single-DB mode.
BACKUP_DB_URL=jdbc:postgresql://NEON_HOST:5432/DBNAME?sslmode=require
BACKUP_DB_USER=your_neon_user
BACKUP_DB_PASSWORD=your_neon_password
BACKUP_DATABASE_URL=postgresql://USER:PASSWORD@NEON_HOST/DBNAME?sslmode=require

# AWS S3 (uploaded archive storage)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket-name

# Google Gemini (document classification)
GOOGLE_API_KEY=your_google_gemini_api_key

# Shared internal JWT signing secret (must match across services)
INTERNAL_JWT_SECRET=change-me-to-a-long-random-string

# Internal gateway callbacks (defaults work inside docker compose network)
GATEWAY_CALLBACK_URL=http://gateway-service:8080/webhooks/classification-complete
GATEWAY_EXTRACTION_EVENT_URL=http://gateway-service:8080/webhooks/extraction-failed
