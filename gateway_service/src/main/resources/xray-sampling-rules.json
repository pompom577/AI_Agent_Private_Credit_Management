{
  "version": 2,
  "rules": [
    {
      "description": "Health checks are noisy and uninteresting — skip them.",
      "host": "*",
      "http_method": "*",
      "url_path": "/actuator/health",
      "fixed_target": 0,
      "rate": 0.0
    }
  ],
  "default": {
    "fixed_target": 1,
    "rate": 0.1
  }
}
